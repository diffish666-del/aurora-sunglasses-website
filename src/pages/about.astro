---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'About Aurora Sunglasses | Professional Eyewear Manufacturer Since 2015';
const description = 'Learn about Aurora Sunglasses - a professional eyewear manufacturer with 10+ years experience. Custom OEM/ODM designs, global shipping, quality guaranteed.';
const keywords = ['about aurora sunglasses', 'sunglasses manufacturer', 'eyewear factory China', 'OEM sunglasses company', 'optical glasses supplier'];
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <section class="bg-gradient-to-br from-brand-50 to-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-gray-900 mb-6">About Aurora Sunglasses</h1>
        <p class="text-xl text-gray-600">
          Professional eyewear manufacturer dedicated to quality, innovation, and customer satisfaction since 2015.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display text-3xl font-bold text-gray-900 mb-6">Our Story</h2>
          <p class="text-gray-600 mb-4">
            Founded in 2015, Aurora Sunglasses has grown from a small workshop to a leading eyewear manufacturer serving clients in over 50 countries worldwide.
          </p>
          <p class="text-gray-600 mb-4">
            Our journey began with a simple mission: to provide high-quality, affordable eyewear without compromising on style or protection. Today, we specialize in sunglasses, reading glasses, optical frames, and accessories for retailers, distributors, and brands globally.
          </p>
          <p class="text-gray-600">
            With a strong R&D team and commitment to innovation, we develop hundreds of new styles annually, ensuring our partners stay ahead of market trends.
          </p>
        </div>
        <div class="bg-brand-50 rounded-2xl p-8 text-center">
          <div class="grid grid-cols-2 gap-6">
            <div>
              <div class="text-4xl font-bold text-brand-600">10+</div>
              <div class="text-gray-600">Years Experience</div>
            </div>
            <div>
              <div class="text-4xl font-bold text-brand-600">50+</div>
              <div class="text-gray-600">Countries Served</div>
            </div>
            <div>
              <div class="text-4xl font-bold text-brand-600">500+</div>
              <div class="text-gray-600">New Styles/Year</div>
            </div>
            <div>
              <div class="text-4xl font-bold text-brand-600">100%</div>
              <div class="text-gray-600">Satisfaction Rate</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center mb-12">What We Offer</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-800 rounded-xl p-6">
          <div class="text-3xl mb-4">🕶️</div>
          <h3 class="font-display text-xl font-bold mb-2">Sunglasses</h3>
          <p class="text-brand-100">Polarized, UV400 protection, various styles from aviator to cat-eye.</p>
        </div>
        <div class="bg-brand-800 rounded-xl p-6">
          <div class="text-3xl mb-4">👓</div>
          <h3 class="font-display text-xl font-bold mb-2">Reading Glasses</h3>
          <p class="text-brand-100">Multiple diopters, blue light blocking, fashionable frames.</p>
        </div>
        <div class="bg-brand-800 rounded-xl p-6">
          <div class="text-3xl mb-4">🌊</div>
          <h3 class="font-display text-xl font-bold mb-2">Floating Glasses</h3>
          <p class="text-brand-100">Waterproof, buoyant materials for water sports enthusiasts.</p>
        </div>
        <div class="bg-brand-800 rounded-xl p-6">
          <div class="text-3xl mb-4">♻️</div>
          <h3 class="font-display text-xl font-bold mb-2">Eco-Friendly</h3>
          <p class="text-brand-100">Recycled materials, bamboo frames, sustainable packaging.</p>
        </div>
        <div class="bg-brand-800 rounded-xl p-6">
          <div class="text-3xl mb-4">🎉</div>
          <h3 class="font-display text-xl font-bold mb-2">Novelty Glasses</h3>
          <p class="text-brand-100">Fun, unique designs for parties, events, and promotions.</p>
        </div>
        <div class="bg-brand-800 rounded-xl p-6">
          <div class="text-3xl mb-4">📦</div>
          <h3 class="font-display text-xl font-bold mb-2">Cases & Accessories</h3>
          <p class="text-brand-100">Hard and soft cases with custom branding options.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center mb-12">Why Partner With Us?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl mb-4">🎨</div>
          <h3 class="font-semibold text-gray-900 mb-2">Custom Design</h3>
          <p class="text-gray-600">OEM/ODM services with experienced R&D team</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">✅</div>
          <h3 class="font-semibold text-gray-900 mb-2">Quality Control</h3>
          <p class="text-gray-600">Rigorous QC at every production stage</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🚚</div>
          <h3 class="font-semibold text-gray-900 mb-2">Global Shipping</h3>
          <p class="text-gray-600">Fast, reliable delivery worldwide</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="font-semibold text-gray-900 mb-2">Competitive Pricing</h3>
          <p class="text-gray-600">Wholesale prices with MOQ flexibility</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
