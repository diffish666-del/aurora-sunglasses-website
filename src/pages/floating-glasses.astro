---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Floating Sunglasses for Water Sports | Aurora Eyewear';
const description = 'Waterproof floating sunglasses for fishing, boating, swimming. Lightweight materials that stay afloat. Perfect for outdoor enthusiasts.';
const keywords = ['floating sunglasses', 'water sports eyewear', 'fishing sunglasses', 'boating glasses', 'waterproof sunglasses', 'sports sunglasses', 'outdoor eyewear'];
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <section class="bg-gradient-to-br from-brand-50 to-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <div class="text-6xl mb-6">🌊</div>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-gray-900 mb-6">Floating Sunglasses</h1>
        <p class="text-xl text-gray-600 mb-8">Waterproof floating sunglasses for fishing, boating, swimming. Lightweight TR90 and polycarbonate materials that stay afloat. Perfect for outdoor enthusiasts.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-brand-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-brand-700 transition shadow-lg">Request Free Samples</a>
          <a href="/contact" class="bg-white text-brand-600 px-8 py-4 rounded-full font-semibold text-lg hover:bg-gray-50 transition border-2 border-brand-200">Get Wholesale Price</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-gray-900 mb-8 text-center">Key Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="flex items-start space-x-4 bg-gray-50 rounded-xl p-6">
          <div class="w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-brand-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          </div>
          <p class="text-gray-700">Buoyant Design - Naturally floats on water surface</p>
        </div>
        <div class="flex items-start space-x-4 bg-gray-50 rounded-xl p-6">
          <div class="w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-brand-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          </div>
          <p class="text-gray-700">Lightweight Materials - TR90, polycarbonate, or bamboo frames</p>
        </div>
        <div class="flex items-start space-x-4 bg-gray-50 rounded-xl p-6">
          <div class="w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-brand-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          </div>
          <p class="text-gray-700">Secure Fit - Non-slip nose pads and temple grips</p>
        </div>
        <div class="flex items-start space-x-4 bg-gray-50 rounded-xl p-6">
          <div class="w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-brand-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          </div>
          <p class="text-gray-700">UV400 Protection - Full sun protection on the water</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold mb-4">Ready to Order?</h2>
      <p class="text-lg text-brand-100 mb-8">Contact us for wholesale pricing and free samples.</p>
      <a href="/contact" class="inline-block bg-white text-brand-600 px-10 py-4 rounded-full font-semibold text-lg hover:bg-gray-100 transition">Contact Us Now</a>
    </div>
  </section>
</BaseLayout>
